#Calculadora simple
num1=int (input("Ingrese el primer numero:"))
num2=int (input("Ingrese el segundo valor:"))
operacion = (input("Ingrese la operacion +,-,*,/: "))

if operacion == "+":
    resultado=num1 + num2
    print("el resultado es", resultado)
elif operacion == "-":
    resultado=num1 - num2
    print("el resultado es", resultado)
elif operacion == "*":
    resultado=num1 * num2
    print("el resultado es", resultado)
elif operacion == "/":
    resultado=num1 / num2
    print("el resultado es", resultado)
else:
    resultado=num1 / num2
    print("el resultado es", resultado)
